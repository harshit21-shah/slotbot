# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Deepgram ──────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (fallback when Groq fails / rate-limited) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
LLM_PRIMARY=anthropic

# ── Sarvam AI ─────────────────────────────────────────────────────────────────
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cal.com ───────────────────────────────────────────────────────────────────
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CALCOM_API_BASE=https://api.cal.com/v2

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-app.onrender.com   # ngrok URL in dev
DATABASE_URL=data/clinics.db
LOG_LEVEL=INFO
ENVIRONMENT=development                      # development | production
USE_SARVAM_PLAY=false                        # true = Sarvam voice (slower, needs tunnel)
